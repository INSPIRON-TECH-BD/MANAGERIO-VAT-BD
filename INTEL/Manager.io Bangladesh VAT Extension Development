// BANGLADESH VAT RATES
// Source: NBR VAT Act 2012 + SROs (2025-2026)
// n-Law 01: Zero Approximation. Never estimate. NBR source only.
// ================================================================
var BD_RATES = {
  "0.15"  : "15%",
  "0.075" : "7.5%",
  "0.05"  : "5%",
  "0"     : "0% (Zero-rated)"
};

function inferRate(base, vat) {
  if (!base || base <= 0 || vat <= 0) return { pct: "\u2014", rate: 0 };
  var r       = vat / base;
  var rounded = Math.round(r * 1000) / 1000;
  var pct     = BD_RATES[String(rounded)] || (Math.round(r * 1000) / 10) + "%";
  return { pct: pct, rate: rounded };
}

// ================================================================
// UTILITIES
// ================================================================
function pad(n) { return n < 10 ? "0" + n : "" + n; }

function fmtDate(d) {
  if (!d) return "";
  var dt = new Date(d);
  if (isNaN(dt.getTime())) return d;
  return pad(dt.getDate()) + "/" + pad(dt.getMonth() + 1) + "/" + dt.getFullYear();
}

// BDT number formatter — BD comma convention
function fmtBDT(n) {
  if (n === null || n === undefined || isNaN(n)) return "0.00";
  return parseFloat(n).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
}

function validateBIN(b) {
  if (!b) return false;
  return b.replace(/\D/g, "").length === 9;
}

function escHtml(s) {
  if (!s) return "";
  return String(s)
    .replace(/&/g,  "&amp;")
    .replace(/</g,  "&lt;")
    .replace(/>/g,  "&gt;")
    .replace(/"/g,  "&quot;");
}

function setStatus(type, msg) {
  var map = { ok: "sok", loading: "sl", error: "se", wait: "sw" };
  document.getElementById("sd").className = "sdot " + (map[type] || "sw");
  document.getElementById("st").textContent = msg;
}

