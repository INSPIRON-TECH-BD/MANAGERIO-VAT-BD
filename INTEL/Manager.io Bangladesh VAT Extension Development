    var ri    = inferRate(base, vat);
    var flag  = "";

    if (gross > 0 && vat === 0) { flag = "No VAT recorded"; warnCount++; }
    if (!inv.customer && !inv.Customer) { flag = flag || "Missing buyer"; }

    totBase  += base;
    totVAT   += vat;
    totGross += gross;

    rows.push({
