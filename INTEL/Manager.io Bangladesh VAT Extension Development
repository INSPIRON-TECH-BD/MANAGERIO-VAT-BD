  var totVAT   = 0;
  var totGross = 0;
  var warnCount = 0;

  invoices.forEach(function(inv, idx) {
    // Manager.io list endpoints return camelCase
    var date  = inv.date      || inv.Date      || "";
    var ref   = inv.reference || inv.Reference || "\u2014";
    var buyer = inv.customer  || inv.Customer  || "Unknown";
    var gross = parseFloat(inv.amount    || inv.Amount    || 0);
