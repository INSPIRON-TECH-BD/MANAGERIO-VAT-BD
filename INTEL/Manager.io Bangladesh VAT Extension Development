var EP = "", TK = "", RDY = false;

window.addEventListener("message", function(e) {
  if (!e.data || e.data.type !== "manager-context") return;
  var p = e.data.payload;
  if (!p || !p.apiEndpoint || !p.apiAccessToken) return;
  EP  = p.apiEndpoint.replace(/\/+$/, "");
  TK  = p.apiAccessToken;
  RDY = true;
  setStatus("ok", "Connected to Manager.io \u2014 select period and click Generate.");
