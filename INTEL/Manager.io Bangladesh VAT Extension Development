  h.push("<th>&#2458;&#2494;&#2482;&#2494;&#2472; No. Invoice</th>");
  h.push("<th>&#2453;&#2381;&#2480;&#2503;&#2468;&#2494;&#2480; &#2472;&#2494;&#2478; Buyer</th>");
  h.push("<th>&#2474;&#2467;&#2509;&#2479; / &#2488;&#2503;&#2476;&#2494; Description</th>");
  h.push("<th class=r>&#2478;&#2482;&#2509;&#2479; Base Value (BDT)</th>");
  h.push("<th class=cn>&#2478;&#2496;&#2488;&#2453; &#2489;&#2494;&#2480; VAT %</th>");
