  h.push("<div class=ef><label>Period &#2456;&#2478;&#2479;&#2492;&#2453;&#2494;&#2354;</label><span>" + sd + " to " + ed + "</span></div>");
  h.push("</div></div>");

  // ── Table ───────────────────────────────────────────────────────
  h.push("<table>");
  h.push("<thead><tr>");
  h.push("<th class=cn>&#2325;&#2381;&#2352;&#2478;&#2495;&#2453; # Serial</th>");
